  dialogueLines:
  - speakerID: NPC
    dialogueText: "\uC800\uAE30.. \uC232\uC5D0\uC11C \uB098\uC628 \uAC70\uC8E0?"
    typeSpeedMultiplier: 0.5
    voiceClip: {fileID: 0}
  - speakerID: NPC
    dialogueText: "\uD639\uC2DC.. \uC232\uC5D0\uC11C \uC774\uC0C1\uD55C \uAC70 \uBABB
      \uBD24\uC5B4\uC694?"
