    voiceClip: {fileID: 0}
  - speakerID: NPC
    dialogueText: "\uC800\uB3C4 \uC798 \uBAA8\uB974\uACA0\uC5B4\uC694.. \uB9C8\uCE58
      \uC2DC\uAC04\uC774 \uBA48\uCD98\uAC83\uAC19\uC544\uC694"
    typeSpeedMultiplier: 0.5
    voiceClip: {fileID: 0}
  - speakerID: NPC
    dialogueText: "\uBC29\uAE08 \uC804\uC5D0\uB294 \uBC14\uB78C\uC774 \uAC11\uC790\uAE30
      \uBA48\uCDC4\uC5B4\uC694"
    typeSpeedMultiplier: 0.5
    voiceClip: {fileID: 0}
  - speakerID: NPC
    dialogueText: "\uC0C8\uB4E4\uB3C4 \uACF5\uC911\uC5D0\uC11C \uBA48\uCDC4\uB2E4\uAC00
      \uB2E4\uC2DC \uB0A0\uC544\uAC00\uACE0\uC694"
    typeSpeedMultiplier: 0.5
    voiceClip: {fileID: 0}
  - speakerID: NPC
    dialogueText: "\uB124.. \uADF8\uB9AC\uACE0 \uC232 \uAE4A\uC740 \uACF3\uC5D0\uC11C
      \uC774\uC0C1\uD55C \uBE5B\uB3C4 \uBD24\uC5B4\uC694"
    typeSpeedMultiplier: 0.5
    voiceClip: {fileID: 0}
  - speakerID: NPC
    dialogueText: "\uC800\uD76C \uB9C8\uC744\uC774 \uAC71\uC815\uB418\uB124\uC694.."
